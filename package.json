{
  "name": "volleyball",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "preview": "expo start --no-dev --minify",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "node --test --import tsx \"engine/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "sim:web": "node sim-web/build.cjs --serve",
    "sim:web:build": "node sim-web/build.cjs",
    "sim:web:check": "tsc --noEmit --lib es2020,dom --module esnext --moduleResolution bundler --target es2020 --skipLibCheck sim-web/main.ts"
  },
  "private": true,
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "babel-preset-expo": "~54.0.10",
    "expo": "^54",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-google-mobile-ads": "^16.4.0",
    "react-native-purchases": "^10.4.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "~19.1.10",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2"
  }
}
