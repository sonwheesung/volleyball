{
  "expo": {
    "name": "배구명가",
    "slug": "volleyball",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "volleyball",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B1018",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.son0925.volleyball"
    },
    "android": {
      "package": "com.son0925.volleyball",
      "versionCode": 1,
      "backgroundColor": "#0B1018",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
