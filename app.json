{
  "expo": {
    "name": "배구명가",
    "slug": "volleyball",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "volleyball",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B1018",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.son0925.volleyball"
    },
    "android": {
      "package": "com.son0925.volleyball",
      "versionCode": 2,
      "backgroundColor": "#0B1018",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-audio",
        {
          "microphonePermission": false
        }
      ],
      "expo-font",
      "expo-asset",
      "@react-native-google-signin/google-signin",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2731473780180274~2622190257"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "09515027-a8b3-4ace-902b-ee759e446c63"
      }
    },
    "owner": "shs00925"
  }
}
