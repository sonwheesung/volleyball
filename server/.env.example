# 배구명가 백엔드 환경변수 (실제 값은 .env.local 에 — 절대 커밋 금지, BACKEND_SYSTEM §13.4 M4)
# P1 스캐폴드는 이 값들 없이도 부팅된다(stub). 아래는 이후 마일스톤에서 채운다.

# ── DB (Supabase Postgres — BACKEND_SYSTEM §13.7) ──
# 런타임(앱/서버리스)은 Transaction 풀러(:6543) 문자열을 쓴다. db/index.ts가 prepare:false로 붙는다.
#   Supabase 대시보드 → Project Settings → Database → Connection string → "Transaction pooler"
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres
# 마이그레이션(drizzle-kit push)만은 Session/Direct(:5432) 문자열로 실행:
#   DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:5432/postgres" npx drizzle-kit push

# ── 세션 서명 (마일스톤 3, 자체 Bearer JWT) ──
SESSION_JWT_SECRET=dev-only-change-me

# ── 소셜 로그인 검증 (마일스톤 3) — 클라 ID토큰의 audience 검증용 ──
GOOGLE_OAUTH_CLIENT_IDS=            # 콤마구분(android/ios/web 클라이언트 ID)
APPLE_BUNDLE_ID=                    # com.yourco.volleyball

# ── 결제 검증 (마일스톤 5) ──
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=   # 서비스계정 JSON(파일경로 또는 base64)
APPLE_ASSN_ISSUER_ID=
APPLE_ASSN_KEY_ID=
APPLE_ASSN_PRIVATE_KEY=             # .p8 내용

# ── AdMob SSV (마일스톤 6) ──
ADMOB_SSV_VERIFY=1

# ── 관리자 대시보드 접근 (requireAdmin fail-closed §13.15 — 반드시 16자 이상, 미만이면 관리자 기능 전면 차단) ──
ADMIN_TOKEN=change-me-min-16-chars-random

# ── 크론(데이터 파기/롤업, §13.10) — Vercel이 크론콜에 Bearer로 자동 첨부. Vercel env에도 동일값 설정 ──
CRON_SECRET=dev-cron-secret

# ── Sentry (서버 에러 관측, §13.21) — 비우면 완전 비활성(부팅 안전). Sentry 프로젝트 생성 → DSN 붙여넣기 ──
#   Sentry.io → Create Project(Platform: Node.js) → Client Keys(DSN) 복사. Vercel env에도 동일 설정.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1      # 성능 트레이스 샘플율(0~1). 트래픽 늘면 낮춤
